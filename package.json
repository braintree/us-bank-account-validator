{
  "name": "us-bank-account-validator",
  "version": "1.1.0",
  "description": "A library for validating US Bank Account routing and account numbers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:braintree/us-bank-account-validator"
  },
  "homepage": "https://github.com/braintree/us-bank-account-validator",
  "scripts": {
    "prepublishOnly": "npm run build",
    "prebuild": "prettier --write .",
    "build": "tsc --declaration",
    "lint": "eslint --ext js,ts .",
    "posttest": "npm run lint",
    "test": "jest",
    "prepare": "husky",
    "commit": "cz"
  },
  "author": "Braintree <code@getbraintree.com> (https://www.braintreepayments.com/)",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^5.54.1",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "eslint": "^8.35.0",
    "eslint-config-braintree": "^6.0.0-typescript-prep-rc.2",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^2.8.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80,
        "branches": 80,
        "functions": 80
      }
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  }
}
